{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "CollectStructured.jsx",
              "components/data-display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:PingFang SC|SF Pro Display))/i]",
        "message": "Font not provided by the design system. Available: PingFang SC, SF Pro Display."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|onBack|right|style|key|ref|className|style|children)$/]",
        "message": "<AppBar> doesn't accept that prop. Declared props: title, onBack, right, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: key, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:home|user|clipboard)$/]",
        "message": "<TabItem> icon must be one of 'home' | 'user' | 'clipboard'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|selectable|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: selected, selectable, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollectBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:method|showLabel|size|key|ref|className|style|children)$/]",
        "message": "<CollectBadge> doesn't accept that prop. Declared props: method, showLabel, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollectBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<CollectBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeviceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|code|model|area|method|itemCount|enabled|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<DeviceCard> doesn't accept that prop. Declared props: name, code, model, area, method, itemCount, enabled, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FieldRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|unit|placeholder|required|readOnly|style|key|ref|className|style|children)$/]",
        "message": "<FieldRow> doesn't accept that prop. Declared props: label, value, onChange, unit, placeholder, required, readOnly, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|prefix|suffix|unit|readOnly|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, prefix, suffix, unit, readOnly, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Input> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SampleListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|code|status|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<SampleListItem> doesn't accept that prop. Declared props: index, code, status, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|onScan|key|ref|className|style|children)$/]",
        "message": "<SearchBar> doesn't accept that prop. Declared props: value, onChange, placeholder, onScan."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|extra|key|ref|className|style|children)$/]",
        "message": "<SectionTitle> doesn't accept that prop. Declared props: children, extra."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|onClick|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, tone, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:pending|testing|done|overdue|brand)$/]",
        "message": "<StatCard> tone must be one of 'pending' | 'testing' | 'done' | 'overdue' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StationBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:station|onSwitch|onClear|style|key|ref|className|style|children)$/]",
        "message": "<StationBar> doesn't accept that prop. Declared props: station, onSwitch, onClear, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|size|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, label, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|size|key|ref|className|style|children)$/]",
        "message": "<StatusTag> doesn't accept that prop. Declared props: status, children, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatusTag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|sampleName|client|time|status|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TaskCard> doesn't accept that prop. Declared props: code, sampleName, client, time, status, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestItemCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|device|status|method|upload|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TestItemCard> doesn't accept that prop. Declared props: name, device, status, method, upload, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestItemCard'] > JSXAttribute[name.name='upload'] > Literal[value!=/^(?:pending|done)$/]",
        "message": "<TestItemCard> upload must be one of 'pending' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|showLabel|size|key|ref|className|style|children)$/]",
        "message": "<UploadStatus> doesn't accept that prop. Declared props: status, showLabel, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadStatus'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|done)$/]",
        "message": "<UploadStatus> status must be one of 'pending' | 'done'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
